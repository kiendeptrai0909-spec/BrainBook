# Sao chép thành file .env (git đã bỏ qua .env).

# PostgreSQL trên máy — cách nhanh (một lần):
#   cd backend
#   powershell -ExecutionPolicy Bypass -File scripts/setup-database.ps1 -PostgresPassword 'MAT_KHAU_SUPERUSER_POSTGRES'
# Script tạo user brainbook / mật khẩu brainbook / database brainbook, rồi chạy migrate + seed.
# Nếu PostgreSQL không ở 18 hoặc psql khác đường dẫn, sửa tham số -PgBin trong scripts/setup-database.ps1

# Chuỗi kết nối (mặc định khớp script). Đổi port/host nếu cần. Ký tự đặc biệt trong mật khẩu → URL-encode.
DATABASE_URL="postgresql://brainbook:brainbook@localhost:5432/brainbook?schema=public"

JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=3000
FRONTEND_URL="http://localhost:5173"
